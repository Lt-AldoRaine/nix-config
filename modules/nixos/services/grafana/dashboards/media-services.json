{
  "dashboard": {
    "title": "Media Services Overview",
    "tags": ["media", "services"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Service Availability",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=~\"jellyfin|lidarr|radarr|sonarr|prowlarr|jellyseerr|qbittorrent|sabnzbd\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Service Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=~\"jellyfin|lidarr|radarr|sonarr|prowlarr|jellyseerr|qbittorrent|sabnzbd\"}[5m]))",
            "legendFormat": "{{job}} p95"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Service Uptime",
        "type": "graph",
        "targets": [
          {
            "expr": "up{job=~\"jellyfin|lidarr|radarr|sonarr|prowlarr|jellyseerr|qbittorrent|sabnzbd\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1
  }
}

